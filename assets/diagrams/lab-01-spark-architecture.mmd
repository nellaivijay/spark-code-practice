        D --> E[Worker Node 1]
        D --> F[Worker Node 2]
        D --> G[Worker Node N]
        
        E --> H[Executor 1]
        E --> I[Executor 2]
        F --> J[Executor 3]
        F --> K[Executor 4]
        G --> L[Executor N]
        
        H --> M[Task]
        I --> N[Task]
        J --> O[Task]
        K --> P[Task]
