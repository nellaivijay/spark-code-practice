# Spark Configuration
SPARK_VERSION=3.5.0
SPARK_MASTER_HOST=localhost
SPARK_MASTER_PORT=7077
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# MinIO Configuration (for S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=spark-data

# PostgreSQL Configuration (for metastore)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=spark_metastore
POSTGRES_USER=spark
POSTGRES_PASSWORD=spark_password

# Spark SQL Configuration
SPARK_SQL_WAREHOUSE_DIR=/opt/spark/warehouse
SPARK_HIVE_METASTORE_URIS=thrift://hive-metastore:9083

# Notebook Configuration
JUPYTER_PORT=8888
JUPYTER_TOKEN=spark-practice
JUPYTER_PASSWORD=spark123

# Data Directories
DATA_DIR=./data
NOTEBOOKS_DIR=./notebooks
SOLUTIONS_DIR=./solutions

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Resource Limits
MAX_CORES=4
MAX_MEMORY=4g

# Network
NETWORK_NAME=spark-practice-network